{
  "$schema": "https://opencode.ai/config.json",

  // LAOS is the orchestration layer. It owns NO domain implementation.
  // Capabilities are exposed via MCP from their own repos.
  "default_agent": "orchestrator",

  // Context loaded automatically into every session.
  "instructions": [
    "AGENTS.md",
    "registry/capabilities.yaml",
    "registry/needs-to-capabilities.yaml",
    "knowledge/glossario-negocio.md",
    "knowledge/padroes-entrega.md",
    "knowledge/stack-decisions.md",
    "knowledge/discover-before-build.md"
  ],

  // Skills come from LAOS itself plus the LADESIGN capability repo.
  "skills": {
    "paths": [
      ".opencode/skill",
      "../ladesign/skills"
    ]
  },

  // MCP servers grouped by role:
  //   - Domain capabilities:   latade, lan8n, lacouncil, laengine, laecon, ladesign
  //   - Platform capabilities: context7, exa, github
  // Toggle `enabled` per project / per session.
  "mcp": {
    // ─── DOMAIN CAPABILITIES ──────────────────────────────────

    // LATADE — data engineering. Real MCP server lives in the LATADE repo.
    // Uses the latade venv (has duckdb, mcp, and latade sources).
    "latade": {
      "type": "local",
      "command": ["..\\latade\\.venv\\Scripts\\python", "..\\latade\\mcp\\server.py"],
      "enabled": true,
      "env": {}
    },

    // LAN8N — n8n automation. Real MCP server lives in the LAN8N repo (../n8n).
    // Uses the LAN8N venv (has mcp and the repo's own server).
    "lan8n": {
      "type": "local",
      "command": ["..\\n8n\\.venv\\Scripts\\python", "..\\n8n\\mcp\\server.py"],
      "enabled": true,
      "env": {}
    },

    // Community n8n MCP server (czlonkowski/n8n-mcp). Talks to a live
    // LAN8N (n8n) instance. Default URL assumes self-hosted local n8n
    // on http://localhost:5678. Enable after running `npx n8n`,
    // enabling the public API in n8n Settings, and putting the API key
    // in .env.
    "n8n-community": {
      "type": "local",
      "command": ["npx", "-y", "n8n-mcp"],
      "enabled": false,
      "env": {
        "N8N_API_URL": "{env:N8N_API_URL}",
        "N8N_API_KEY": "{env:N8N_API_KEY}"
      }
    },

    // LACOUNCIL — failure investigation + improvement engine.
    // Called by LAOS when structural gaps are detected.
    "lacouncil": {
      "type": "local",
      "command": ["..\\lacouncil\\.venv\\Scripts\\python", "..\\lacouncil\\mcp\\server.py"],
      "enabled": true,
      "env": {
        "LACOUNCIL_DB_PATH": "{workspaceFolder}\\..\\lacouncil\\memoria\\lacouncil.duckdb"
      }
    },

    // LACAREEROPS — job search optimization (career-ops CLI wrapper).
    // Repo: github.com/laurentaf/lacareerops (PRIVATE).
    // 7 MCP tools: health, list, evaluate, generate_pdf, scan_portals,
    // batch_process, tracker_list. Uses Node.js career-ops CLI + Python
    // subprocess wrapper. Each user configures their own profile.yml + cv.md.
    // Status: BASIC (2026-06-13). Deadline STABLE: 2026-07-13.
    "lacareerops": {
      "type": "local",
      "command": ["uv", "run", "python", "E:\\projects\\lacareerops\\mcp\\server.py"],
      "enabled": true,
      "env": {}
    },

    // LAENGINE — game development capability (sports simulation, match engine).
    "laengine": {
      "type": "local",
      "command": ["uv", "run", "python", "../laengine/src/laengine/mcp/server.py"],
      "enabled": true,
      "env": {}
    },

    // LAECON — econometrics + interpretable ML.
    // Capability BASIC (cbe2d8ef, 2026-06-04). MCP server at
    // ../laecon/laecon/mcp/server.py. Currently 2 implemented tools
    // (health, list_supported_operations) + 7 stubs. Routed via
    // needs-to-capabilities.yaml for ml, data-science, econometrics,
    // nps-driver-analysis, causal-inference, predictive-modeling.
    // Uses the laecon pyproject deps (uv-managed venv at .venv/).
    "laecon": {
      "type": "local",
      "command": ["uv", "run", "python", "../laecon/laecon/mcp/server.py"],
      "enabled": true,
      "env": {}
    },

    // LADESIGN — design capability (dashboards, decks, wireframes, design systems).
    // MCP server via `od mcp` from the LADESIGN repo.
    // Prerequisites: `pnpm install` in ../ladesign (builds the daemon CLI).
    // The server exposes live-artifact and connector tools for design work.
    "ladesign": {
      "type": "local",
      "command": ["node", "E:\\projects\\ladesign\\apps\\daemon\\dist\\cli.js", "mcp"],
      "enabled": true,
      "env": {
        "OD_DAEMON_URL": "http://localhost:7456"
      }
    },

    // WORKFLOW-DECOMPOSER — WDL v1 plan analyzer (proposal a4fe9faa, supermaioria).
    // Subagent is dispatched by the orchestrator before ANY specialist dispatch.
    // Status: BASIC (cold start, +30d to STABLE). Operates on the SAME lacouncil
    // MCP server (no new server to spawn); the wall is enforced by the subagent
    // charter, not by the MCP config. We declare an entry here so the boot check
    // (3rd dimension) sees the subagent has a resolvable MCP dependency. The
    // dispatcher can pass `mcp_server: lacouncil` in its dispatch payload, and
    // the subagent's charter scopes its tool calls to the lacouncil.* namespace
    // only. See .opencode/agent/workflow-decomposer.md for the MCP wall
    // (WDL-R1: latade.*, ladesign.*, lan8n.*, laecon.*, n8n-community.* all
    // denied) and workflows/wdl-contract.yaml for the operating contract.
    "workflow-decomposer": {
      "type": "reference",
      "mcp_server": "lacouncil",
      "enabled": true,
      "env": {}
      // type=reference (not "local"): the subagent reuses the lacouncil MCP
      // server's stdio process; it does NOT spawn a new one. This avoids
      // resource waste (one Python process per session) and ensures the
      // subagent's read-only MCP access shares the orchestrator's session
      // state. The MCP wall is enforced by the subagent's instruction file
      // (workflow-decomposer.md §"MCP namespaces you must NOT call").
    },

    // ─── PLATFORM CAPABILITIES ────────────────────────────────

    // Context7 - up-to-date library/API docs.
    // Free tier works without a key.
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },

    // Exa - web search. Remote MCP with OAuth on first connection.
    // No API key required. Browser opens on first use to authorize.
    // Docs: https://docs.exa.ai/reference/exa-mcp
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },

    // GitHub - official remote MCP server.
    // Reads GITHUB_TOKEN from OS environment (not .env).
    // Create at https://github.com/settings/tokens with minimal scopes.
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },

  // Permissions for the orchestrator (primary). Subagents narrow this.
  // Per Hard Rule #10 (AGENTS.md, 2026-06-07): file ops under E:/projects/**
  // and bash `git *` are pre-authorized. Subagent frontmatter overrides
  // the top-level wholesale (per knowledge/opencode-permissions.md §2.1).
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "uv *": "allow",
      // subagent_boot_check.py é pre-flight obrigatório (AGENTS.md +
      // stack-decisions.md). Read-only, exit 0/1, sem efeito colateral.
      // Whitelisted aqui porque a chamada inclui redirecionamento 2>&1
      // e chain com Write-Output que o pattern "uv *" não casa.
      "uv run python scripts/subagent_boot_check.py *": "allow",
      "npx *": "allow",
      "rm -rf *": "deny"
    },
    "external_directory": {
      // Per Hard Rule #10 (AGENTS.md, 2026-06-07): all of E:/projects/**
      // is pre-authorized. No catch-all "ask" — every legitimate path
      // is covered by the umbrella below. Individual repo entries kept
      // as explicit fallback for glob edge cases (dotfiles, backslash).
      "E:/projects/**": "allow",
      "../latade/**": "allow",
      "../lan8n/**": "allow",
      "../ladesign/**": "allow",
      "../laengine/**": "allow",
      "../lacouncil/**": "allow",
      "../laecon/**": "allow",
      "E:/projects/lacareerops/**": "allow"
    }
  }
}
