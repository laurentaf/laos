{
  "$schema": "https://opencode.ai/config.json",

  // LAOS is the orchestration layer. It owns NO domain implementation.
  // Capabilities are exposed via MCP from their own repos.
  "default_agent": "orchestrator",

  // Context loaded automatically into every session.
  "instructions": [
    "AGENTS.md",
    "registry/capabilities.yaml",
    "registry/needs-to-capabilities.yaml",
    "knowledge/glossario-negocio.md",
    "knowledge/padroes-entrega.md",
    "knowledge/stack-decisions.md",
    "knowledge/discover-before-build.md"
  ],

  // Skills come from LAOS itself plus the LADESIGN capability repo.
  "skills": {
    "paths": [
      ".opencode/skill",
      ".opencode/skills",
      "../ladesign/skills"
    ]
  },

  // MCP servers grouped by role:
  //   - Domain capabilities:   latade, lan8n, lacouncil, laengine, laecon, ladesign
  //   - Platform capabilities: context7, exa, github
  // Toggle `enabled` per project / per session.
  "mcp": {
    // ─── DOMAIN CAPABILITIES ──────────────────────────────────

    // LATADE — data engineering. Real MCP server lives in the LATADE repo.
    // Uses pythonw.exe (windowless) to avoid flashing console windows.
    // pythonw.exe still has stdin/stdout for MCP stdio protocol — it just
    // doesn't allocate a visible console. (Same for all local MCP entries.)
    "latade": {
      "type": "local",
      "command": ["..\\latade\\.venv\\Scripts\\pythonw", "..\\latade\\mcp\\server.py"],
      "enabled": true,
      "env": {}
    },

    // LAN8N — n8n automation. Real MCP server lives in the LAN8N repo (../lan8n).
    // Uses pythonw.exe (windowless) to avoid flashing console windows.
    "lan8n": {
      "type": "local",
      "command": ["..\\lan8n\\.venv\\Scripts\\pythonw", "-m", "lan8n.mcp.server"],
      "enabled": true,
      "env": {}
    },

    // Community n8n MCP server (czlonkowski/n8n-mcp). Talks to a live
    // LAN8N (n8n) instance. Default URL assumes self-hosted local n8n
    // on http://localhost:5678. Enable after running `npx n8n`,
    // enabling the public API in n8n Settings, and putting the API key
    // in .env.
    "n8n-community": {
      "type": "local",
      "command": ["npx", "-y", "n8n-mcp"],
      "enabled": false,
      "env": {
        "N8N_API_URL": "{env:N8N_API_URL}",
        "N8N_API_KEY": "{env:N8N_API_KEY}"
      }
    },

    // LACOUNCIL — failure investigation + improvement engine.
    // Called by LAOS when structural gaps are detected.
    "lacouncil": {
      "type": "local",
      "command": ["..\\lacouncil\\.venv\\Scripts\\pythonw", "..\\lacouncil\\mcp\\server.py"],
      "enabled": true,
      "env": {
        "LACOUNCIL_DB_PATH": "{workspaceFolder}\\lacouncil\\memoria\\lacouncil.duckdb"
      }
    },

    // LAENGINE — game development capability (sports simulation, match engine).
    // Uses pythonw.exe (windowless) to avoid flashing console windows.
    "laengine": {
      "type": "local",
      "command": ["..\\laengine\\.venv\\Scripts\\pythonw", "..\\laengine\\src\\laengine\\mcp\\server.py"],
      "enabled": true,
      "env": {}
    },

    // LAECON — econometrics + interpretable ML.
    // Capability BASIC (cbe2d8ef, 2026-06-04). MCP server at
    // ../laecon/laecon/mcp/server.py. Currently 2 implemented tools
    // (health, list_supported_operations) + 7 stubs. Routed via
    // needs-to-capabilities.yaml for ml, data-science, econometrics,
    // nps-driver-analysis, causal-inference, predictive-modeling.
    // Uses pythonw.exe (windowless) to avoid flashing console windows.
    "laecon": {
      "type": "local",
      "command": ["..\\laecon\\.venv\\Scripts\\pythonw", "..\\laecon\\laecon\\mcp\\server.py"],
      "enabled": true,
      "env": {}
    },

    // LADESIGN — design capability (dashboards, decks, wireframes, design systems).
    // ATENÇÃO: O repo em ../ladesign contém o projeto Open Design (Node.js/TypeScript),
    // NÃO o servidor Python MCP esperado em src/ladesign/mcp/server.py que não existe.
    // Issue estrutural: repositório não corresponde ao declarado em capabilities.yaml.
    // Desabilitado até que o servidor Python MCP correto seja implementado ou o path
    // seja ajustado via LACOUNCIL.
    // O repo tem um MCP server TypeScript em apps/daemon/src/mcp.ts (via `od mcp`).
    "ladesign": {
      "type": "local",
      "command": ["..\\ladesign\\.venv\\Scripts\\pythonw", "..\\ladesign\\src\\ladesign\\mcp\\server.py"],
      "enabled": false,
      "env": {}
    },

    // WORKFLOW-DECOMPOSER — WDL v1 plan analyzer (proposal a4fe9faa, supermaioria).
    // Subagent is dispatched by the orchestrator before ANY specialist dispatch.
    // Status: BASIC (cold start, +30d to STABLE). Operates on the SAME lacouncil
    // MCP server (no new server to spawn); the wall is enforced by the subagent
    // charter, not by the MCP config. We declare an entry here so the boot check
    // (3rd dimension) sees the subagent has a resolvable MCP dependency. The
    // dispatcher can pass `mcp_server: lacouncil` in its dispatch payload, and
    // the subagent's charter scopes its tool calls to the lacouncil.* namespace
    // only. See .opencode/agent/workflow-decomposer.md for the MCP wall
    // (WDL-R1: latade.*, ladesign.*, lan8n.*, laecon.*, n8n-community.* all
    // denied) and workflows/wdl-contract.yaml for the operating contract.
    "workflow-decomposer": {
      "type": "reference",
      "mcp_server": "lacouncil",
      "enabled": true,
      "env": {}
      // type=reference (not "local"): the subagent reuses the lacouncil MCP
      // server's stdio process; it does NOT spawn a new one. This avoids
      // resource waste (one Python process per session) and ensures the
      // subagent's read-only MCP access shares the orchestrator's session
      // state. The MCP wall is enforced by the subagent's instruction file
      // (workflow-decomposer.md §"MCP namespaces you must NOT call").
    },

    // ─── TOOLING & INFRA CAPABILITIES ────────────────────────

    // LAOS.INFRA — 5 MCP infrastructure tools for tooling maintenance,
    // binary download, and agent validation. Created via LACOUNCIL
    // proposal 6481da60 (supermaioria 4/4, 2026-06-14).
    // Tools: health_check, add_tool, scaffold_mcp, download_file,
    // validate_agent. Also carries the original laos-doctor diagnostic.
    // Implements as an OpenCode plugin (.opencode/plugins/laos-infra.ts)
    // that exports custom tools — no separate MCP server process needed.
    "laos.infra": {
      "type": "reference",
      "mcp_server": "laos-doctor",
      "enabled": true,
      "env": {},
      "notes": "Plugin-based .opencode/plugins/laos-infra.ts. Tools auto-available."
    },

    // ─── PLATFORM CAPABILITIES ────────────────────────────────

    // Context7 - up-to-date library/API docs.
    // Free tier works without a key.
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },

    // Exa - web search. Remote MCP with OAuth on first connection.
    // No API key required. Browser opens on first use to authorize.
    // Docs: https://docs.exa.ai/reference/exa-mcp
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },

    // GitHub - official remote MCP server.
    // Reads GITHUB_TOKEN from OS environment (not .env).
    // Create at https://github.com/settings/tokens with minimal scopes.
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },

  // Permissions for the orchestrator (primary). Subagents narrow this.
  // Per Hard Rule #10 (AGENTS.md, 2026-06-07): file ops under E:/projects/**
  // and bash `git *` are pre-authorized. Subagent frontmatter overrides
  // the top-level wholesale (per knowledge/opencode-permissions.md §2.1).
  "provider": {
    "nvidia": {
      "models": {
        "minimaxai/minimax-m3": {
          "name": "MiniMax-M3",
          "family": "minimax",
          "attachment": false,
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 1000000,
            "output": 8192
          },
          "cost": {
            "input": 0,
            "output": 0
          },
          "status": "active"
        }
      }
    }
  },
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      // Hard rule (2026-06-21): TWO values only — `allow` and `deny`.
      // No `ask` anywhere. Paths not covered below are blocked (deny).
      // Adding a new command = explicit allowlist entry (no implicit trust).
      //
      // ─── REGRA ABSOLUTA: ZERO BINÁRIOS DE CONSOLE ──────────
      // NENHUM binário CONSOLE subsystem (uv.exe, git.exe, python.exe,
      // npx.cmd, docker.exe) pode ser executado diretamente via bash tool.
      // TODO(S) criam janela de console no Windows, mesmo que brevemente.
      //
      // Apenas WINDOWS subsystem binaries (pythonw.exe) são permitidos.
      // pythonw.exe NUNCA aloca console, em nenhuma circunstância.
      // Internamente, run_hidden.run() usa CREATE_NO_WINDOW (0x08000000)
      // para que subprocessos de console também não criem janela.
      //
      // ─── ENTRADAS 100% HIDDEN ────────────────────────────────
      // Via pythonw.exe (GUI subsystem) + run_hidden.py (CREATE_NO_WINDOW)
      ".venv/Scripts/pythonw.exe": "allow",
      ".venv/Scripts/pythonw.exe *": "allow",
      ".venv/Scripts/pythonw.exe scripts/run-hidden.py *": "allow",
      ".venv/Scripts/pythonw.exe scripts/subagent_boot_check.py *": "allow",
      ".venv/Scripts/pythonw.exe scripts/toolchain_inventory.py *": "allow",
      ".venv/Scripts/pythonw.exe scripts/preflight_check.py *": "allow",
      // ─── SEM FALLBACKS ──────────────────────────────────────
      // NÃO há entradas para uv, git, npx, docker ou python.exe.
      // Se o orchestrator precisar de algo não coberto, DEVE usar
      // .venv/Scripts/pythonw.exe scripts/run-hidden.py <comando>
      // para garantir execução sem janela.
      "rm -rf *": "deny"
    },
    "external_directory": {
      // Per Hard Rule #10 (AGENTS.md, 2026-06-07): all of E:/projects/**
      // is pre-authorized. No catch-all — every legitimate path is
      // explicitly listed below. Individual repo entries kept as
      // explicit fallback for glob edge cases (dotfiles, backslash).
      "E:/projects/**": "allow",
      "../latade/**": "allow",
      "../lan8n/**": "allow",
      "../ladesign/**": "allow",
      "../laengine/**": "allow",
      "../lacouncil/**": "allow",
      "../laecon/**": "allow",
      "../career-ops/**": "allow"
    }
  }
}
