{
  "$schema": "https://opencode.ai/config.json",

  // LAOS is the orchestration layer. It owns NO domain implementation.
  // Capabilities are exposed via MCP from their own repos.
  "default_agent": "orchestrator",

  // Context loaded automatically into every session.
  "instructions": [
    "AGENTS.md",
    "registry/capabilities.yaml",
    "registry/needs-to-capabilities.yaml",
    "knowledge/glossario-negocio.md",
    "knowledge/padroes-entrega.md",
    "knowledge/stack-decisions.md"
  ],

  // Skills come from LAOS itself plus the LADESIGN capability repo.
  "skills": {
    "paths": [
      ".opencode/skill",
      "../ladesign/skills"
    ]
  },

  // MCP servers grouped by role:
  //   - Domain capabilities:   latade, lan8n, LADESIGN
  //   - Platform capabilities: context7, exa, github
  // Toggle `enabled` per project / per session.
  "mcp": {
    // ─── DOMAIN CAPABILITIES ──────────────────────────────────

    // LATADE — data engineering. Stub server lives in LAOS until the
    // real LATADE repo (../latade) ships its own mcp/server.py.
    // Run via the LAOS local venv (created by `uv sync`).
    "latade": {
      "type": "local",
      "command": ["uv", "run", "python", "capabilities-stubs/latade-mcp/server.py"],
      "enabled": true,
      "env": {}
    },

    // LAN8N — n8n automation. Stub server in LAOS until the
    // LAN8N repo (../lan8n) ships its own MCP server.
    "lan8n": {
      "type": "local",
      "command": ["uv", "run", "python", "capabilities-stubs/lan8n-mcp/server.py"],
      "enabled": true,
      "env": {}
    },

    // Community n8n MCP server (czlonkowski/n8n-mcp). Talks to a live
    // LAN8N (n8n) instance. Default URL assumes self-hosted local n8n
    // on http://localhost:5678. Enable after running `npx n8n`,
    // enabling the public API in n8n Settings, and putting the API key
    // in .env.
    "n8n-community": {
      "type": "local",
      "command": ["npx", "-y", "n8n-mcp"],
      "enabled": false,
      "env": {
        "N8N_API_URL": "{env:N8N_API_URL}",
        "N8N_API_KEY": "{env:N8N_API_KEY}"
      }
    },

    // LAENGINE — game development capability (sports simulation, match engine).
    "laengine": {
      "type": "local",
      "command": ["uv", "run", "python", "../laengine/src/laengine/mcp/server.py"],
      "enabled": true,
      "env": {}
    },

    // LADESIGN — design capability (dashboards, decks, wireframes, design systems).
    // Install the LADESIGN CLI via `od mcp install opencode` and enable.
    // The previous MCP key was `open-design`; if the install command still
    // uses that name, manually point it to this entry or recreate it.
    "ladesign": {
      "type": "local",
      "command": ["od", "mcp", "serve"],
      "enabled": false,
      "env": {}
    },

    // ─── PLATFORM CAPABILITIES ────────────────────────────────

    // Context7 - up-to-date library/API docs.
    // Free tier works without a key.
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },

    // Exa - web search. Remote MCP with OAuth on first connection.
    // No API key required. Browser opens on first use to authorize.
    // Docs: https://docs.exa.ai/reference/exa-mcp
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },

    // GitHub - official remote MCP server.
    // Reads GITHUB_TOKEN from OS environment (not .env).
    // Create at https://github.com/settings/tokens with minimal scopes.
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },

  // Permissions for the orchestrator (primary). Subagents narrow this.
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "uv *": "allow",
      "npx *": "allow",
      "rm -rf *": "deny"
    },
    "external_directory": {
      "*": "ask",
      "../latade/**": "allow",
      "../lan8n/**": "allow",
      "../ladesign/**": "allow",
      "../laengine/**": "allow"
    }
  }
}
